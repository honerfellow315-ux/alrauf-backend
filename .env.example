# =============================================
# ALRauf Fragrances - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/alrauf-db?retryWrites=true&w=majority

# JWT Secret (use a long random string)
JWT_SECRET=alrauf_super_secret_key_change_this_in_production_2024
JWT_EXPIRES_IN=30d

# Cloudinary (for product images)
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (change these!)
ADMIN_EMAIL=admin@alrauf.pk
ADMIN_PASSWORD=Admin@123456

# Frontend URL (for CORS)
FRONTEND_URL=https://alrauf-frontend-git-main-honerfellow315-ux156.vercel.app
